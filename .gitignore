# --- VSCodium ---
VSCodium/*
!VSCodium/User/
VSCodium/User/*
!VSCodium/User/settings.json
!VSCodium/User/keybindings.json
!VSCodium/User/tasks.json
!VSCodium/User/cheatsheet.md
!VSCodium/User/snippets/
VSCodium/User/History/
VSCodium/User/workspaceStorage/
VSCodium/User/globalStorage/
VSCodium/User/chatSessions/

# --- VSCode (legacy, remove once fully on VSCodium) ---
Code/

# --- EasyEffects ---
# Back up your presets, but ignore the runtime state
easy-effects/*
!easy-effects/input/
!easy-effects/output/

# --- Fish Shell ---
# Keep your functions and config, ignore history and completions
fish/*
!fish/config.fish
!fish/functions/
!fish/conf.d/
fish/fish_variables
fish/fish_history
fish/functions/br.fish

# --- Mise ---
# Mise usually tracks local tool versions in the project folder,
# but ignore the internal data/cache if it's in .config
mise/cache/
mise/downloads/
mise/mise.local.toml

# --- Zellij ---
# Ignore layouts you don't want to track or temp files
zellij/cache/

# --- General Linux Bloat ---
**/*.log
**/Cache*/
**/cache*/
**/tmp/
.DS_Store
.aider*

# --- Neovim ---
nvim/deps/
nvim/undo/
nvim/shada/
nvim/view/
nvim/backup/
nvim/lazy-lock.json
nvim/.luarc.json
nvim/.neoconf.json
nvim/spell/*.add
nvim/spell/*.add.spl

# --- COSMIC ---
cosmic/com.system76.CosmicPortal/v1/
cosmic/com.system76.CosmicSettings.Wallpaper/v1/
cosmic/com.system76.CosmicBackground/v1/
cosmic/com.system76.CosmicPanel.Panel/v1/

.gemini/
gha-creds-*.json
.github
