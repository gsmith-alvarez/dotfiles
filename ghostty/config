theme = Catppuccin Mocha

# Basic Settings
title = Hello
command = ~/.local/share/mise/shims/zellij attach -c
shell-integration = fish
quick-terminal-position = center
quick-terminal-key = alt+space

# Clipboard Settings
clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard

# Font Settings - Quotes are only needed if there are spaces in the name
font-family = "GeistMono NF UltraBlack"
font-size = 13
window-title-font-family = "GeistMono NF UltraBlack"
mouse-hide-while-typing = true
cursor-style = block
cursor-blink = false

# Window Effects
background-opacity = 0.85
background-blur = true
refresh-rate = 0
window-subtitle = working-directory
window-padding-x = 12
window-padding-y = 12
unfocused-split-opacity = 0.7
window-decoration = false

quit-after-last-window-closed = false
