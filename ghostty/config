theme = Catppuccin Mocha

# Basic Settings
#title = Hello
# command = ~/.local/share/mise/shims/zellij attach -c
command = fish
shell-integration = fish

# Clipboard Settings
clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard

# Font Settings - Quotes are only needed if there are spaces in the name
font-family = "GeistMono NF UltraBlack"
font-size = 13
window-title-font-family = "GeistMono NF UltraBlack"
mouse-hide-while-typing = true
cursor-style = block

# Window Effects
background-opacity = 0.85
background-blur = true
window-subtitle = working-directory
window-padding-x = 12
window-padding-y = 12
unfocused-split-opacity = 0.7
window-decoration = false

quit-after-last-window-closed = false

# Custom Keybindings (Ctrl+Alt Layer for Ghostty Native)
keybind = ctrl+alt+n=new_split:auto
keybind = ctrl+alt+x=close_surface
keybind = ctrl+alt+h=goto_split:left
keybind = ctrl+alt+j=goto_split:bottom
keybind = ctrl+alt+k=goto_split:top
keybind = ctrl+alt+l=goto_split:right
keybind = ctrl+alt+t=new_tab
keybind = ctrl+alt+w=close_tab
keybind = ctrl+alt+[=previous_tab
keybind = ctrl+alt+]=next_tab
keybind = ctrl+alt+f=toggle_fullscreen
keybind = ctrl+alt+shift+h=resize_split:left,10
keybind = ctrl+alt+shift+j=resize_split:down,10
keybind = ctrl+alt+shift+k=resize_split:up,10
keybind = ctrl+alt+shift+l=resize_split:right,10
