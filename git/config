[core]
    # Keep delta as the standard pager for logs/blame
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    dark = true
    line-numbers = true
    side-by-side = false
[diff]
    # Enable structural diffs via difftastic
    # This is a game-changer for code reviews
    external = difft
    colorMoved = default
[merge]
