// VSCodium keybindings — paired with lua/core/vscode.lua
// Editor-level leader maps (<leader>ff, gd, etc.) are handled by vscode-neovim
// via core/vscode.lua. This file covers VSCode UI contexts outside the editor
// (panels, terminal, quick-open, suggestions).
[
    // ================================================================
    // PANE NAVIGATION  (mirrors smart-splits.nvim <C-hjkl>)
    // Works in both editor (neovim passes through) and non-editor UI.
    // ================================================================
    { "key": "ctrl+h", "command": "workbench.action.navigateLeft" },
    { "key": "ctrl+l", "command": "workbench.action.navigateRight" },
    { "key": "ctrl+k", "command": "workbench.action.navigateUp" },
    { "key": "ctrl+j", "command": "workbench.action.navigateDown" },

    // ================================================================
    // EDITOR SPLITS  (fallback when not in neovim normal mode)
    // ================================================================
    { "key": "ctrl+w v", "command": "workbench.action.splitEditor" },
    { "key": "ctrl+w s", "command": "workbench.action.splitEditorDown" },
    { "key": "ctrl+w q", "command": "workbench.action.closeActiveEditor" },

    // ================================================================
    // BUFFER NAVIGATION  (mirrors H / L in non-editor contexts)
    // ================================================================
    {
        "key": "shift+h",
        "command": "workbench.action.previousEditorInGroup",
        "when": "!editorTextFocus"
    },
    {
        "key": "shift+l",
        "command": "workbench.action.nextEditorInGroup",
        "when": "!editorTextFocus"
    },

    // ================================================================
    // TERMINAL  (mirrors <C-\> toggle + <Esc><Esc> exit)
    // ================================================================
    { "key": "ctrl+`", "command": "workbench.action.terminal.toggleTerminal" },
    {
        "key": "escape escape",
        "command": "workbench.action.terminal.focus",
        "when": "terminalFocus"
    },

    // ================================================================
    // QUICK-OPEN NAVIGATION  (mirrors ctrl+j/k in snacks.picker)
    // ================================================================
    {
        "key": "ctrl+j",
        "command": "workbench.action.quickOpenSelectNext",
        "when": "inQuickOpen"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.quickOpenSelectPrevious",
        "when": "inQuickOpen"
    },

    // ================================================================
    // COMPLETION NAVIGATION  (mirrors blink.cmp ctrl+j/k/l)
    // ================================================================
    {
        "key": "ctrl+j",
        "command": "selectNextSuggestion",
        "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
    },
    {
        "key": "ctrl+k",
        "command": "selectPrevSuggestion",
        "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
    },
    {
        "key": "ctrl+l",
        "command": "acceptSelectedSuggestion",
        "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
    },
    {
        "key": "ctrl+j",
        "command": "showNextParameterHint",
        "when": "editorFocus && parameterHintsMultipleSignatures && parameterHintsVisible"
    },
    {
        "key": "ctrl+k",
        "command": "showPrevParameterHint",
        "when": "editorFocus && parameterHintsMultipleSignatures && parameterHintsVisible"
    },
    {
        "key": "ctrl+j",
        "command": "selectNextCodeAction",
        "when": "codeActionMenuVisible"
    },
    {
        "key": "ctrl+k",
        "command": "selectPrevCodeAction",
        "when": "codeActionMenuVisible"
    },
    {
        "key": "ctrl+l",
        "command": "acceptSelectedCodeAction",
        "when": "codeActionMenuVisible"
    },

    // ================================================================
    // OUTLINE / SYMBOL TREE  (mirrors aerial.nvim ctrl+j/k navigation)
    // ================================================================
    {
        "key": "ctrl+j",
        "command": "list.focusDown",
        "when": "listFocus && !inputFocus"
    },
    {
        "key": "ctrl+k",
        "command": "list.focusUp",
        "when": "listFocus && !inputFocus"
    }
]
