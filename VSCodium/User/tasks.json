{
    "version": "2.0.0",
    "tasks": [
        // ================================================================
        // WORKFLOW UTILITIES  (mirrors snacks.terminal TUI factory)
        // ================================================================
        {
            "label": "Open Workflow Cheatsheet",
            "type": "shell",
            "command": "codium",
            "args": ["${userHome}/.config/VSCodium/User/cheatsheet.md"],
            "presentation": { "reveal": "never", "echo": false },
            "problemMatcher": []
        },
        {
            "label": "Aider AI",
            "type": "shell",
            "command": "aider",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true,
                "echo": false
            },
            "problemMatcher": []
        },
        {
            "label": "Process Monitor (btm)",
            "type": "shell",
            "command": "btm",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true,
                "echo": false
            },
            "problemMatcher": []
        },
        {
            "label": "Spotify Player",
            "type": "shell",
            "command": "spotify_player",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true,
                "echo": false
            },
            "problemMatcher": []
        },
        {
            "label": "LazyGit",
            "type": "shell",
            "command": "lazygit",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true,
                "echo": false
            },
            "problemMatcher": []
        },
        // ================================================================
        // PLATFORMIO  (mirrors workflow/toggleterm.lua PIO commands)
        // ================================================================
        {
            "label": "PIO: Build",
            "type": "shell",
            "command": "pio run",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "PIO: Upload",
            "type": "shell",
            "command": "pio run --target upload",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "PIO: Monitor",
            "type": "shell",
            "command": "pio device monitor",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "problemMatcher": []
        },
        {
            "label": "PIO: Generate Compilation DB",
            "type": "shell",
            "command": "pio project init --ide=vscode",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        }
    ]
}
